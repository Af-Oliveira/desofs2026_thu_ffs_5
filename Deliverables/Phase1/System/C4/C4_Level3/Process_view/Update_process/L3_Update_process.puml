@startuml
title Update Process (Level 3) — VendNet

actor "Actor\n(Operator/Admin)" as User

box "VendNet API" #LightBlue
    participant "Controller" as Controller
    participant "Service" as Service
    participant "Repository" as Repository
end box

box "Domain" #LightGreen
    entity "Domain Model" as DomainModel
end box

database "Persistence Layer (DB)" as DB

User -> Controller: Request Update with Data (ID, DTO)
activate Controller
Controller -> Controller: Validate Input Data (DTO)
alt Input Valid
    Controller -> Service: Delegate Update(ID, data)
    activate Service
    Service -> Repository: Find Existing Object(ID)
    activate Repository
    Repository -> DB: Query Existing Data
    activate DB
    DB --> Repository: Existing Raw Data
    deactivate DB
    Repository -> DomainModel: Reconstitute Existing Domain Model
    activate DomainModel
    DomainModel --> Repository: Existing Domain Model Object
    deactivate DomainModel
    Repository --> Service: Existing Domain Model Object
    deactivate Repository
    alt Object Found
        Service -> DomainModel: Apply Updates & Validate Business Rules
        activate DomainModel
        DomainModel --> Service: Updated Object / Validation Result
        deactivate DomainModel
        alt Business Rules Pass
            Service -> Repository: Save(Updated Domain Model Object)
            activate Repository
            Repository -> DB: Update Persistent Data
            activate DB
            DB --> Repository: Data Updated
            deactivate DB
            Repository --> Service: Updated Object
            deactivate Repository
            Service --> Controller: Update Successful (Domain Model Object)
           
            Controller -> Controller: Map Domain Model to DTO
            Controller --> User: Success Message (Updated DTO)
        else Business Rules Fail
            Service --> Controller: Business Rule Violation

            Controller --> User: Error Message (Business Rule Failure)
        end
    else Object Not Found
        Service --> Controller: Object Not Found
        deactivate Service
        Controller --> User: Error Message (Object Not Found)
    end
else Input Invalid
    Controller --> User: Error Message (Invalid Input)
end
deactivate Controller
@enduml



