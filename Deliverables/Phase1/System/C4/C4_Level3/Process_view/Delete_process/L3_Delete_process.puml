@startuml
title Delete Process (Level 3) — VendNet

actor "Actor\n(Operator/Admin)" as User

box "VendNet API" #LightBlue
    participant "Controller" as Controller
    participant "Service" as Service
    participant "Repository" as Repository
end box

box "Domain" #LightGreen
    entity "Domain Model" as DomainModel
end box

database "Persistence Layer (DB)" as DB

User -> Controller: Request Deletion (ID)
activate Controller
Controller -> Controller: Validate Request Parameters
alt Parameters Valid
    Controller -> Service: Delete(ID)
    activate Service
    Service -> Repository: Find Object(ID) (for validation/existence check)
    activate Repository
    Repository -> DB: Query Existing Data
    activate DB
    DB --> Repository: Raw Data
    deactivate DB
    Repository -> DomainModel: Reconstitute Domain Model
    activate DomainModel
    DomainModel --> Repository: Domain Model Object
    deactivate DomainModel
    Repository --> Service: Existing Domain Model Object
    deactivate Repository
    alt Object Exists
        Service -> Service: Apply Deletion Business Rules
        alt Deletion Rules Pass
            Service -> Repository: Delete(Domain Model Object)
            activate Repository
            Repository -> DB: Remove Data
            activate DB
            DB --> Repository: Data Removed
            deactivate DB
            Repository --> Service: Deletion Successful
            deactivate Repository
            Service --> Controller: Deletion Successful
            
            Controller --> User: Success Message
        else Deletion Rules Fail
            Service --> Controller: Deletion Rule Violation
    
            Controller --> User: Error Message (Cannot Delete)
        end
    else Object Does Not Exist
        Service --> Controller: Object Not Found
        deactivate Service
        Controller --> User: Error Message (Object Not Found)
    end
else Parameters Invalid
    Controller --> User: Error Message (Invalid Parameters)
end
deactivate Controller
@enduml