@startuml
title Create Process (Level 3) — VendNet

actor "Actor\n(Customer/Operator/Admin)" as User

box "VendNet API" #LightBlue
    participant "Controller" as Controller
    participant "Service" as Service
    participant "Repository" as Repository
end box

box "Domain" #LightGreen
    entity "Domain Model" as DomainModel
end box

database "Persistence Layer (DB)" as DB

User -> Controller: Request Creation with Data (DTO)
activate Controller
Controller -> Controller: Validate Input Data (DTO)
alt Input Valid
    Controller -> Service: Create(data)
    activate Service
    Service -> DomainModel: Create New Domain Model Object
    activate DomainModel
    DomainModel --> Service: New Object
    deactivate DomainModel
    Service -> Service: Apply Business Rules
    alt Business Rules Pass
        Service -> Repository: Save(Domain Model Object)
        activate Repository
        Repository -> DB: Persist Data
        activate DB
        DB --> Repository: Data Stored
        deactivate DB
        Repository --> Service: Saved Object
        deactivate Repository
        Service --> Controller: Creation Successful (Domain Model Object)
        Controller -> Controller: Map Domain Model to DTO
        Controller --> User: Success Message (Created DTO)
    else Business Rules Fail
        Service --> Controller: Business Rule Violation
        deactivate Service
        Controller --> User: Error Message (Business Rule Failure)
    end
else Input Invalid
    Controller --> User: Error Message (Invalid Input)
end
deactivate Controller
@enduml