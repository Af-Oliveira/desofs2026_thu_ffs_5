@startuml
title Read/List Process (Level 2) — VendNet

actor "Actor\n(Customer/Operator/Admin)" as User

box "VendNet API" #LightBlue
    participant "Controller" as Controller
    participant "Service" as Service
end box

User -> Controller: Request Data (ID/Criteria)
activate Controller
Controller -> Controller: Validate Request Parameters
alt Parameters Valid
    Controller -> Service: Read(ID/Criteria)
    activate Service
    alt Data Found
        Service --> Controller: Data Found (Domain Model Object(s))
        Controller -> Controller: Map Domain Model to DTO
        Controller --> User: Display Requested Data (DTO)
    else Data Not Found
        Service --> Controller: Data Not Found
        deactivate Service
        Controller --> User: Error Message (Data Not Found)
    end
else Parameters Invalid
    Controller --> User: Error Message (Invalid Parameters)
end
deactivate Controller
@enduml