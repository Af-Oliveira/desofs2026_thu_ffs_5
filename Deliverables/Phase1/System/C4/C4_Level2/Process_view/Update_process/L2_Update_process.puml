@startuml
title Update Process (Level 2) — VendNet

actor "Actor\n(Operator/Admin)" as User

box "VendNet API" #LightBlue
    participant "Controller" as Controller
    participant "Service" as Service
end box

User -> Controller: Request Update with Data (ID, DTO)
activate Controller
Controller -> Controller: Validate Input Data (DTO)
alt Input Valid
    Controller -> Service: Update(ID, data)
    activate Service
    alt Object Found
        alt Business Rules Pass
            Service --> Controller: Update Successful (Domain Model Object)
            Controller -> Controller: Map Domain Model to DTO
            Controller --> User: Success Message (Updated DTO)
        else Business Rules Fail
            Service --> Controller: Business Rule Violation
            Controller --> User: Error Message (Business Rule Failure)
        end
    else Object Not Found
        Service --> Controller: Object Not Found
        deactivate Service
        Controller --> User: Error Message (Object Not Found)
    end
else Input Invalid
    Controller --> User: Error Message (Invalid Input)
end
deactivate Controller
@enduml



